# Use PyTorch with CUDA runtime base image
FROM pytorch/pytorch:2.2.1-cuda12.1-cudnn8-runtime

# Set working directory inside container
WORKDIR /app

# Install system packages required for audio processing and compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    espeak-ng \
    libasound2-dev \
    libsndfile1-dev \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Clone the Piper codebase containing piper_train
RUN git clone https://github.com/rhasspy/piper.git /app/piper

# Install Python requirements and compile the custom C++ monotonic_align alignment extension
RUN cd /app/piper/src/python && \
    pip install --no-cache-dir cython && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir -e . && \
    ./build_monotonic_align.sh

# Create persistent storage directories inside container
RUN mkdir -p /datasets /training_runs

# Keeping the container alive by default to allow users to execute commands or run scripts
CMD ["tail", "-f", "/dev/null"]
